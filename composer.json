{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "intentui/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework with Inertia.js and Justd.",
    "keywords": [
        "laravel",
        "framework",
        "intentui",
        "inertia"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "cviebrock/eloquent-sluggable": "^13.0",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.27",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.9",
        "maatwebsite/excel": "4.x-dev",
        "spatie/laravel-data": "^4.23",
        "spatie/laravel-permission": "^7.4",
        "spatie/laravel-query-builder": "^7.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.2",
        "laravel/pail": "^1.2",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": [
            "@php vendor/bin/phpstan analyse --memory-limit=2G --debug --no-progress"
        ],
        "check": [
            "@format:test",
            "@analyse",
            "@test"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "pnpm check",
            "@check"
        ],
        "format": [
            "pint"
        ],
        "format:test": [
            "pint --test"
        ],
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "pnpm exec concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"./phpw artisan serve\" \"./phpw artisan queue:listen --tries=1\" \"./phpw artisan pail --timeout=0\" \"pnpm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
