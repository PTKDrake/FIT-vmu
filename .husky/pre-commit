#!/bin/sh

wayfinder_inputs_changed() {
  git diff --cached --name-only -- app/Http/Controllers routes | grep -q .
}

stage_wayfinder_outputs() {
  if ! wayfinder_inputs_changed; then
    return
  fi

  if [ ! -x "./phpw" ]; then
    printf '%s\n' "wayfinder: ./phpw not found; skipping generated types refresh."
    return
  fi

  printf '%s\n' "wayfinder: generating action and route types."
  if ! ./phpw artisan wayfinder:generate --with-form --path=web >/dev/null; then
    printf '%s\n' "wayfinder: generation failed; aborting commit." >&2
    exit 1
  fi

  git add web/actions web/routes
}

stage_wayfinder_outputs

pnpm exec lint-staged