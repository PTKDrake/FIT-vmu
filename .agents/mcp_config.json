{
    "mcpServers": {
        "laravel-boost": {
            "command": "wsl.exe",
            "args": [
                "/root/.local/share/pvm/versions/8.5.6/bin/php",
                "/root/Project/FIT-vmu/artisan",
                "boost:mcp"
            ]
        },
        "shadcn": {
            "command": "pnpx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        },
        "react-aria": {
            "command": "pnpx",
            "args": [
                "@react-aria/mcp@latest"
            ]
        }
    }
}