{
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build && vite build --ssr",
        "build:ssr": "vite build && vite build --ssr",
        "check": "pnpm doctor && pnpm typecheck",
        "dev": "vite",
        "doctor": "react-doctor -y --offline --verbose --fail-on error",
        "doctor:staged": "react-doctor -y --offline --staged --verbose --fail-on warning",
        "doctor:strict": "react-doctor -y --offline --verbose --fail-on warning",
        "format": "prettier --write web/",
        "format:check": "prettier --check web/",
        "lint": "oxlint --config .oxlintrc.json web",
        "lint:check": "pnpm lint",
        "lint:eslint": "eslint web",
        "lint:fix": "oxlint --config .oxlintrc.json --fix web",
        "preview": "tsc && pnpm run build:ssr && ./phpw artisan inertia:start-ssr",
        "typecheck": "tsgo --noEmit",
        "typecheck:tsc": "tsc --noEmit",
        "types:check": "pnpm typecheck:tsc"
    },
    "devDependencies": {
